		{
			"name": "App Health (no /metrics - metrics via OTel)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/health",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3001",
					"path": [
						"health"
					]
				},
				"description": "App does not expose /metrics. To see app metrics: 1) Ensure Docker is running (docker compose -f docker-compose-dev.yml up -d). 2) App must push to OTel at localhost:4317. 3) Use 'OTel Collector Metrics' request with URL: http://localhost:8889/metrics (requires Docker port 8889 exposed). 4) Generate traffic (e.g. run load-generator or hit /api/users, /api/orders) so OTel exports data."
			},
			"response": []
		},
		{
			"name": "OTel Collector Metrics (app metrics here)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8889/metrics",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8889",
					"path": [
						"metrics"
					]
				},
				"description": "App metrics exposed by OTel Collector. Prerequisites: 1) Docker stack running (docker compose -f docker-compose-dev.yml up -d). 2) App running on host (npm run dev in app/) and sending OTLP to http://localhost:4317. 3) Generate some traffic (load-generator or curl /api/users, /api/orders). Then this URL shows http_server_duration_milliseconds_* etc. If empty, check app logs for OTel errors and that port 4317 is reachable."
			},
			"response": []
		},
		{
			"name": "Prometheus Targets",
			"request": {
				"method": "GET",
				"header": [],

				},
				"description": "Get OTel Collector internal telemetry metrics"
			},
			"response": []
		},
		{
			"name": "Prometheus Query - App Metrics (OTel)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:9090/api/v1/query?query=http_server_duration_milliseconds_count",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "9090",
					"path": [
						"api",
						"v1",
						"query"
					],
					"query": [
						{
							"key": "query",
							"value": "http_server_duration_milliseconds_count"
						}
					]
				},
				"description": "Query Prometheus for app metrics (scraped from OTel collector :8889). Data appears after: app running, traffic generated, Prometheus scraped collector (wait ~15s)."
			},
			"response": []
		},
		{
			"name": "Prometheus Query - OTel Metrics",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:9090/api/v1/query?query=http_server_duration_milliseconds_count",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "9090",
					"path": [
						"api",
						"v1",
						"query"
					],
					"query": [
						{
							"key": "query",
							"value": "http_server_duration_milliseconds_count"
						}
					]
				},
				"description": "Query Prometheus for OTel metrics (from collector)"
			},
			"response": []
		},
		{
			"name": "Prometheus Query - Request Rate (OTel)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:9090/api/v1/query?query=rate(http_server_duration_milliseconds_count[1m])",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "9090",
					"path": [
						"api",
						"v1",
						"query"
					],
					"query": [
						{
							"key": "query",
							"value": "rate(http_server_duration_milliseconds_count[1m])"
						}
					]
				},
				"description": "Request rate from OTel metrics (used in Grafana Service Overview)"
			},
			"response": []
		},
